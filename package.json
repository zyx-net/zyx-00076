{
  "name": "contract-approval-api",
  "version": "1.0.0",
  "description": "合同审批路由与归档 API",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "seed": "node src/seeders/seed.js",
    "test-flow": "node tests/test-flow.js",
    "test-failures": "node tests/test-failures.js",
    "test-rules": "node tests/test-rules-import-export.js",
    "test-persistence": "node tests/test-persistence-restart.js",
    "test-roundtrip": "node tests/test-export-import-roundtrip.js",
    "test-import-summary": "node tests/test-import-summary.js",
    "test-import-summary-persistence": "node tests/test-import-summary-persistence.js",
    "test-batch-traceability": "node tests/test-batch-traceability.js",
    "test-batch-persistence": "node tests/test-batch-persistence.js",
    "test-deadline-sla": "node tests/test-deadline-sla.js",
    "test-deadline-reminder-regression": "node tests/test-deadline-reminder-regression.js",
    "process-reminders": "node -e \"const db = require('./src/database/db'); const DeadlineService = require('./src/services/DeadlineService'); db.load(); const results = DeadlineService.processAutomaticReminders(); console.log('催办处理结果:', JSON.stringify(results, null, 2)); db.forceSave();\""
  },
  "dependencies": {
    "express": "^4.18.2",
    "uuid": "^9.0.1",
    "joi": "^17.11.0",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}
